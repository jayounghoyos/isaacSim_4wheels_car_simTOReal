<mujoco model="train_scene">
  <include file="robot.xml"/>
  <visual>
    <global offwidth="1280" offheight="720"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3"/>
  </visual>
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.12 0.17 0.23"
             width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="6 6" reflectance="0.1"/>
  </asset>
  <worldbody>
    <light pos="0 0 6" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="40 40 0.1" material="grid"/>
    <!-- target cube (mocap; env randomizes its position). Sized for the ~1.5 m robot. -->
    <body name="target" pos="6 0 0.3" mocap="true">
      <geom name="target" type="box" size="0.3 0.3 0.3" rgba="0.9 0.2 0.1 1" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
